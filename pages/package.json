{
  "name": "bookmark-navigator-pages",
  "private": true,
  "version": "1.0.0",
  "description": "Deployment wrapper for Cloudflare Pages.",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev",
    "dev:local": "wrangler pages dev --local",
    "deploy": "wrangler pages deploy ../public --branch main --commit-dirty=true"
  },
  "dependencies": {
    "jose": "^5.2.0"
  },
  "devDependencies": {
    "wrangler": "^4.72.0"
  }
}
